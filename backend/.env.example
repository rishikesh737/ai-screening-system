# App
APP_ENV=development
SECRET_KEY=changeme

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pgagi_db

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_AI_ML=knowledge_aiml

# Groq (LLM for question generation — free tier at console.groq.com)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Embedding model (local, via sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Interview config
MAX_QUESTIONS=8
QUESTIONS_PER_TOPIC=2
